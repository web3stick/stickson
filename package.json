{
  "name": "@web3stick/stickson",
  "version": "0.0.2",
  "description": "JSON framework for making static pages",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "stickson": "./bin/stickson.js"
  },
  "files": [
    "dist/",
    "bin/",
    "schema/",
    "themes/",
    "README.md",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/web3stick/stickson.git"
  },
  "homepage": "https://github.com/web3stick/stickson",
  "scripts": {
    "build": "tsc",
    "dev": "bun run --watch src/index.ts",
    "tsc": "tsc --noEmit",
    "prettier": "prettier . --write",
    "typecheck": "bun run tsc && bun run prettier",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "static",
    "site",
    "generator",
    "json",
    "html",
    "template"
  ],
  "author": "web3stick.near",
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "chokidar": "^5.0.0",
    "express": "^5.2.1"
  }
}
