{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stickson Content Schema",
  "description": "Schema for stickson static page content JSON files",
  "type": "object",
  "required": ["version", "page"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version for compatibility",
      "const": "1.0"
    },
    "meta": {
      "type": "object",
      "description": "Page metadata",
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "author": {
          "type": "string"
        },
        "lang": {
          "type": "string",
          "default": "en"
        },
        "favicon": {
          "type": "string",
          "format": "uri"
        },
        "ogImage": {
          "type": "string",
          "format": "uri"
        }
      },
      "additionalProperties": false
    },
    "theme": {
      "type": "object",
      "description": "Theme configuration",
      "properties": {
        "name": {
          "type": "string"
        },
        "cssFile": {
          "type": "string"
        },
        "customCss": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "template": {
      "type": "object",
      "description": "HTML template configuration",
      "properties": {
        "file": {
          "type": "string"
        },
        "headExtra": {
          "type": "string"
        },
        "bodyExtra": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "routes": {
      "type": "object",
      "description": "Named route definitions linking to other JSON files",
      "patternProperties": {
        "^[a-zA-Z_][a-zA-Z0-9_-]*$": {
          "type": "string",
          "description": "Path to linked JSON file"
        }
      },
      "additionalProperties": false
    },
    "page": {
      "type": "object",
      "description": "Main page content structure",
      "required": ["head", "body"],
      "properties": {
        "head": {
          "type": "array",
          "description": "Head section elements",
          "items": {
            "$ref": "#/definitions/element"
          }
        },
        "body": {
          "type": "array",
          "description": "Body section elements",
          "items": {
            "$ref": "#/definitions/element"
          }
        }
      },
      "additionalProperties": false
    }
  },
